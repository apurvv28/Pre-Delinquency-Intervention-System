# Application
APP_TIMEZONE=Asia/Kolkata
FRONTEND_URL=http://localhost:8080
CORS_ALLOW_ORIGINS=http://localhost:8080

# Database (container-local SQLite persisted via Docker volume)
DATABASE_URL=sqlite:///./data/pie.db

# Optional Upstash Redis (leave blank to run with in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_STREAM_KEY=pie:transactions
REDIS_CONSUMER_GROUP=pie-prediction-engine
REDIS_CONSUMER_NAME=pie-worker-1

# Model artifact paths (mount your model files into these locations)
MODEL_PATH=models/pie_lightgbm_model_v2.pkl
FEATURES_PATH=models/pie_feature_columns_v2.pkl
THRESHOLD_PATH=models/pie_threshold_v2.pkl

# Startup flags
SKIP_SEED_ON_STARTUP=false
DISABLE_TRANSACTION_STREAM=false
PRESEED_TRANSACTIONS_ON_STARTUP=false
DISABLE_RETRAINING_SCHEDULER=true
USE_ADVANCED_STREAM_PRODUCER=true
